# Copy to .env and fill in your values
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True

# LLM Configuration (leave blank to use mock agent mode)
OPENAI_API_KEY=

# Optional: Use a different LLM provider via LiteLLM
# LLM_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=

# Mock mode: set to True to skip real LLM calls (default: True when no API key)
TPMO_MOCK_AGENTS=True
